{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python claude_docs/meta-agent/agent.py --bootstrap"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f claude_docs/meta-agent/agent.py ] && python claude_docs/meta-agent/agent.py --bootstrap || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python claude_docs/meta-agent/agent.py --review"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f claude_docs/meta-agent/agent.py ] && python claude_docs/meta-agent/agent.py --review || true"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python claude_docs/meta-agent/agent.py --consolidate"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f claude_docs/meta-agent/agent.py ] && python claude_docs/meta-agent/agent.py --consolidate || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python claude_docs/meta-agent/agent.py --finalize"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f claude_docs/meta-agent/agent.py ] && python claude_docs/meta-agent/agent.py --finalize || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Users/irphy/.claude/hooks/pre_tool_gate.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(python *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(pip *)",
      "Bash(node *)",
      "Bash(powershell *)",
      "Bash(mkdir *)",
      "Bash(cd *)",
      "Bash(dir *)",
      "Bash(type *)",
      "Bash(echo *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "mcp__*",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch(domain:*)",
      "Bash(python:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(git:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(cat:*)",
      "Bash(type:*)",
      "Bash(more:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(copy:*)",
      "Bash(move:*)",
      "Bash(mv:*)",
      "Bash(ren:*)",
      "Bash(rename:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(sort:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(xxd:*)",
      "Bash(tar:*)",
      "Bash(unzip:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(powershell:*)",
      "Bash(powershell.exe:*)",
      "Bash(cmd:*)",
      "Bash(source:*)",
      "Bash(done)",
      "Bash(set:*)",
      "Bash(export:*)",
      "Bash(chmod:*)",
      "Bash(\"C:/Users/irphy/*\")",
      "Bash(playwright:*)",
      "mcp__suno-mcp__*",
      "mcp__ableton-mcp__*",
      "mcp__rekordbox-mcp__*",
      "MultiEdit",
      "View",
      "LS",
      "Task",
      "Bash(pretext:*)",
      "Bash(pandoc:*)",
      "Bash(gh:*)",
      "Bash(winget:*)",
      "Bash(del:*)",
      "Bash(rmdir:*)",
      "Bash(chown:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(whereis:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(del /f /s /q *)",
      "Read(.env)",
      "Read(.env.*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf C:*)",
      "Bash(del /s /q C:\\*)",
      "Bash(format:*)",
      "Bash(sudo rm -rf:*)",
      "Bash(rmdir /s /q C:\\*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(reg delete:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf ./*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod 777:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Read(./secrets/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)"
    ]
  }
}